<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS reverse proxy → app Next (PM2 em http://localhost:3000).
  Requer os módulos do IIS: URL Rewrite + Application Request Routing (ARR, com "Enable proxy" ligado).
  Coloque este web.config na raiz do site IIS que tem o binding HTTPS (443) + certificado TLS.
  Objetivo: navegador fala HTTPS com o IIS; o IIS repassa para o app em HTTP local.
  O cabeçalho X-Forwarded-Proto=https é essencial para o cookie de sessão (Secure) funcionar.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Redireciona HTTP → HTTPS (evita cookie inseguro) -->
        <rule name="RedirectToHttps" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Repassa todo o tráfego HTTPS para o app Next local -->
        <rule name="ReverseProxyToNext" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Timeouts maiores: respostas de IA em streaming podem demorar -->
    <proxy timeout="00:04:00" />
  </system.webServer>
</configuration>
