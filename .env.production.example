# ============================================================
# Ítala (ITS Brasil) — Produção (Windows Server)
# Copie para .env.production e preencha. NÃO versione o arquivo real.
# ============================================================

# ---- Sessão (obrigatório) ----
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ---- Banco Postgres LOCAL do Windows Server ----
# Sem SSL em banco local: a string NÃO deve ter sslmode=require.
POSTGRES_URL=postgres://itsbrasil:TROQUE_A_SENHA@localhost:5432/itsbrasil

# ---- Motor de IA: gateway Mangaba em OUTRA MÁQUINA da rede (sem túnel) ----
# Chamada é servidor-para-servidor → pode ser HTTP puro na LAN.
OPENAI_BASE_URL=http://192.168.X.Y:PORTA/v1
OPENAI_MODEL=mangaba-pro
OPENAI_MODEL_FALLBACKS=mangaba-max,mangaba-lite-q4
OPENAI_VISION_MODEL=mangaba-vision-q8
OPENAI_API_KEY=none

# ---- Painel /admin (e-mails separados por vírgula) ----
ADMIN_EMAILS=voce@itsbrasil.net
